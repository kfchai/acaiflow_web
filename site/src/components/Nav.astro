---
interface Props {
  solid?: boolean;
}
const { solid = false } = Astro.props;

const links = [
  { href: '/', label: 'home' },
  { href: '/story', label: 'our story' },
  { href: '/menu', label: 'menu' },
  { href: '/calculator', label: 'macro calculator' },
  { href: '/order', label: 'order online' },
  { href: '/catering', label: 'catering' },
  { href: '/location', label: 'location' },
  { href: '/contact', label: 'contact' },
];
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const wrapperClass = solid
  ? 'sticky top-0 inset-x-0 z-40 bg-cream-warm/95 backdrop-blur border-b border-ink/10'
  : 'absolute top-0 inset-x-0 z-40';

const logoClass = solid
  ? 'h-14 md:h-16 w-auto'
  : 'h-14 md:h-16 w-auto brightness-0 invert';

const linkBase = solid ? 'text-ink' : 'text-cream-warm';
const summaryColor = solid ? 'text-ink' : 'text-cream-warm';
const mobileMenuClass = solid
  ? 'absolute right-0 mt-3 w-56 bg-cream-warm/98 backdrop-blur rounded-xl shadow-xl p-2 border border-ink/10'
  : 'absolute right-0 mt-3 w-56 bg-ink/95 backdrop-blur rounded-xl shadow-xl p-2';
const mobileItemClass = solid
  ? 'block px-4 py-2.5 rounded-lg text-[11px] uppercase tracking-[0.2em] text-ink hover:bg-ink/5'
  : 'block px-4 py-2.5 rounded-lg text-[11px] uppercase tracking-[0.2em] text-cream-warm/90 hover:bg-cream-warm/10';
---

<header class={wrapperClass}>
  <nav class="max-w-7xl mx-auto px-6 py-6 flex items-center justify-between gap-6">
    <a href="/" class="flex items-center gap-2">
      <img src="/logo.svg" alt="AcaiFlow" class={logoClass} />
    </a>
    <ul class="hidden lg:flex items-center gap-7 text-[11px] uppercase tracking-[0.2em]">
      {links.slice(1).map((l) => (
        <li>
          <a
            href={l.href}
            class:list={[
              'transition-opacity',
              linkBase,
              pathname === l.href ? 'opacity-100' : 'opacity-75 hover:opacity-100',
            ]}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
    <details class="lg:hidden relative">
      <summary class:list={['list-none cursor-pointer', summaryColor]}>
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </summary>
      <ul class={mobileMenuClass}>
        {links.map((l) => (
          <li>
            <a href={l.href} class={mobileItemClass}>
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </details>
  </nav>
</header>
