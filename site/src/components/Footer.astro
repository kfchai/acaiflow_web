---
const year = new Date().getFullYear();
---

<footer class="bg-berry text-cream-warm mt-24">
  <div class="max-w-6xl mx-auto px-5 py-14 grid gap-10 md:grid-cols-4">
    <div class="md:col-span-2">
      <img src="/logo.svg" alt="AcaiFlow" class="h-9 w-auto brightness-0 invert opacity-90 mb-4" />
      <p class="text-sm leading-relaxed opacity-90 max-w-sm">
        Superfood. Glow. Vibe. Real food that makes you feel good — served fresh, every day.
      </p>
    </div>
    <div>
      <h4 class="text-sm uppercase tracking-wider mb-3 opacity-70">Visit</h4>
      <address class="not-italic text-sm leading-relaxed opacity-90">
        Ground Floor, Green Heights Mall<br />
        88 Jalan Hijau, 50480 Kuala Lumpur<br />
        <br />
        Mon–Fri · 9am–9pm<br />
        Sat–Sun · 8am–10pm
      </address>
    </div>
    <div>
      <h4 class="text-sm uppercase tracking-wider mb-3 opacity-70">Follow</h4>
      <ul class="text-sm space-y-2 opacity-90">
        <li><a href="https://instagram.com/acaiflow.my" class="hover:underline">@acaiflow.my</a></li>
        <li><a href="mailto:hello@acaiflow.my" class="hover:underline">hello@acaiflow.my</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-cream-warm/15">
    <div class="max-w-6xl mx-auto px-5 py-5 text-xs opacity-70 flex flex-wrap gap-3 justify-between">
      <span>© {year} AcaiFlow. Let's flow together 🌿</span>
      <span>Made in Kuala Lumpur</span>
    </div>
  </div>
</footer>
