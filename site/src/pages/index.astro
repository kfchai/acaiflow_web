---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import menu from '../data/menu.json';

const sections = [
  { title: 'our story', href: '/story', image: '/heroes/story.jpg', tagline: 'eat well, feel good' },
  { title: 'menu', href: '/menu', image: '/heroes/menu.jpg', tagline: menu.season.tagline },
  { title: 'macro calculator', href: '/calculator', image: '/heroes/calculator.jpg', tagline: 'know what goes into your meals' },
  { title: 'order online', href: '/order', image: '/heroes/order.jpg', tagline: 'a tap away from your bowl' },
  { title: 'catering', href: '/catering', image: '/heroes/catering.jpg', tagline: 'our kitchen to your event' },
  { title: 'location', href: '/location', image: '/heroes/location.jpg', tagline: 'come say hi' },
];
---

<Layout>
  <PageHero
    image="/heroes/home.jpg"
    eyebrow="superfood · glow · vibe"
    title="eat well, feel good."
    height="full"
  >
    <div class="mt-10 flex justify-center">
      <a
        href="/menu"
        class="inline-flex items-center gap-3 rounded-full border border-cream-warm/40 hover:bg-cream-warm hover:text-ink text-cream-warm text-[11px] uppercase tracking-[0.3em] px-7 py-3 transition-colors"
      >
        Enter
      </a>
    </div>
  </PageHero>

  <section class="bg-cream-warm">
    <div class="max-w-4xl mx-auto px-6 py-28 md:py-40 text-center">
      <p class="text-coffee uppercase tracking-[0.3em] text-[10px] mb-7">welcome to acaiflow</p>
      <h2 class="italic-display text-4xl md:text-6xl lg:text-7xl leading-[1.05] text-ink lowercase">
        a better way to eat,<br />every day.
      </h2>
      <p class="mt-10 text-coffee/80 max-w-2xl mx-auto leading-relaxed">
        Eating healthy isn't always easy, but we believe it should be. That's why we started AcaiFlow — to make wholesome eating easy, so you can focus on feeling your best every day.
      </p>
      <a
        href="/story"
        class="inline-block mt-10 text-[11px] uppercase tracking-[0.3em] text-ink border-b border-ink pb-1 hover:text-berry hover:border-berry transition-colors"
      >
        Read our story
      </a>
    </div>
  </section>

  {sections.map((s, i) => (
    <a href={s.href} class="group block">
      <section class="relative overflow-hidden min-h-[60vh] md:min-h-[70vh] flex items-center justify-center text-center">
        <img
          src={s.image}
          alt=""
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-ink/60 group-hover:bg-ink/50 transition-colors"></div>
        <div class="relative max-w-3xl px-6">
          <p class="text-cream-warm/75 uppercase tracking-[0.3em] text-[10px] md:text-xs mb-4">
            0{i + 1} — {s.tagline}
          </p>
          <h3 class="italic-display text-cream-warm text-5xl md:text-7xl lowercase leading-[1.05]">
            {s.title}
          </h3>
          <span class="inline-block mt-7 text-cream-warm/80 text-[11px] uppercase tracking-[0.3em] border-b border-cream-warm/40 pb-1 group-hover:text-cream-warm group-hover:border-cream-warm">
            Enter →
          </span>
        </div>
      </section>
    </a>
  ))}
</Layout>
