---
import Layout from '../layouts/Layout.astro';
import menu from '../data/menu.json';

const categories = [
  { key: 'acaiBowls', href: '/menu#acai', ...menu.acaiBowls },
  { key: 'smoothies', href: '/menu#smoothies', ...menu.smoothies },
  { key: 'wholefoodBowls', href: '/menu#wholefood', ...menu.wholefoodBowls },
  { key: 'buildYourOwn', href: '/menu#byo', ...menu.buildYourOwn, items: [] as any[] },
];

const heroImage = '/images/PHY_0038.jpg';
---

<Layout>
  <section class="relative overflow-hidden bg-berry text-cream-warm">
    <div class="absolute inset-0 opacity-30">
      <img src={heroImage} alt="" class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="relative max-w-6xl mx-auto px-5 py-24 md:py-36">
      <p class="uppercase tracking-[0.25em] text-xs md:text-sm opacity-80 mb-5">superfood · glow · vibe</p>
      <h1 class="font-display text-5xl md:text-7xl lg:text-8xl leading-[0.95] max-w-3xl">
        Eat well,<br />feel good.
      </h1>
      <p class="mt-7 text-base md:text-lg max-w-xl opacity-90 leading-relaxed">
        Real food that keeps you in flow — nourishing acai bowls, longevity smoothies, and wholefood meals built for daily life.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="/menu" class="inline-flex items-center gap-2 bg-raspberry hover:bg-raspberry/90 text-white font-medium px-6 py-3 rounded-full transition-colors">
          See the menu
        </a>
        <a href="/story" class="inline-flex items-center gap-2 border border-cream-warm/40 hover:bg-cream-warm/10 text-cream-warm font-medium px-6 py-3 rounded-full transition-colors">
          Our story
        </a>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-5 py-20">
    <div class="max-w-2xl mb-10">
      <p class="text-berry font-medium uppercase tracking-wider text-xs mb-3">The Menu</p>
      <h2 class="font-display text-4xl md:text-5xl text-coffee">A better way to eat, every day.</h2>
    </div>
    <div class="grid gap-6 md:grid-cols-2">
      {categories.map((c) => (
        <a
          href={c.href}
          class="group relative rounded-3xl overflow-hidden bg-white border border-berry/10 hover:border-berry/30 transition-all hover:-translate-y-1"
        >
          <div class="aspect-[4/3] bg-cream overflow-hidden">
            {c.items && c.items[0] && c.items[0].image ? (
              <img
                src={c.items[0].image}
                alt={c.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-sand-light to-sand"></div>
            )}
          </div>
          <div class="p-6">
            <h3 class="font-display text-2xl text-berry">{c.title}</h3>
            <p class="text-coffee/70 text-sm mt-1">{c.tagline}</p>
            <p class="text-coffee/60 text-xs mt-3">{c.priceNote}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-cream border-y border-berry/10">
    <div class="max-w-6xl mx-auto px-5 py-20 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-berry font-medium uppercase tracking-wider text-xs mb-3">Our Story</p>
        <h2 class="font-display text-4xl md:text-5xl text-coffee leading-tight">
          Because when you eat well, you flow daily.
        </h2>
        <p class="mt-6 text-coffee/80 leading-relaxed">
          We believe in real food that makes you feel good — nourishing bowls, wholesome ingredients, and flavours that keep your body and spirit in flow. No complicated diets, no calorie anxiety — just clean, balanced meals that fit your daily lifestyle.
        </p>
        <a href="/story" class="inline-flex mt-7 items-center gap-2 text-berry font-medium hover:gap-3 transition-all">
          Read the full story →
        </a>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <img src="/images/PHY_0039.jpg" alt="" class="rounded-2xl aspect-square object-cover" loading="lazy" />
        <img src="/images/PHY_0030.jpg" alt="" class="rounded-2xl aspect-square object-cover mt-8" loading="lazy" />
        <img src="/images/PHY_0018.jpg" alt="" class="rounded-2xl aspect-square object-cover" loading="lazy" />
        <img src="/images/PHY_0047.jpg" alt="" class="rounded-2xl aspect-square object-cover mt-8" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-5 py-20 text-center">
    <p class="text-raspberry font-medium uppercase tracking-wider text-xs mb-3">Know Your Numbers</p>
    <h2 class="font-display text-4xl md:text-5xl text-coffee">How much should you eat?</h2>
    <p class="mt-5 text-coffee/80 leading-relaxed max-w-2xl mx-auto">
      Use our free macro calculator to work out your daily calories and protein, carbs and fat targets — the effortless starting point for feeling good.
    </p>
    <a href="/calculator" class="inline-flex mt-8 items-center gap-2 bg-berry hover:bg-berry-dark text-cream-warm font-medium px-6 py-3 rounded-full transition-colors">
      Open the calculator →
    </a>
  </section>
</Layout>
