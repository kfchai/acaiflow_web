---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import menu from '../data/menu.json';

const boards = [
  { src: '/menu/bowls.jpeg', alt: 'Wholefood Bowls menu', label: 'Wholefood Bowls' },
  { src: '/menu/acai_bowls.jpeg', alt: 'Acai Bowls menu', label: 'Acai Bowls' },
  { src: '/menu/smoothies.jpeg', alt: 'Beverages menu', label: 'Beverages' },
  { src: '/menu/byo_bowl.jpeg', alt: 'Build Your Own Wholesome Bowl menu', label: 'Build Your Own' },
];
---

<Layout title="Menu — AcaiFlow" description="Wholefood bowls, açaí bowls, beverages and build-your-own — the AcaiFlow menu.">
  <PageHero
    image="/heroes/menu.jpg"
    eyebrow="menu"
    title="savor the season"
  />

  <section class="bg-cream-warm">
    <div class="max-w-3xl mx-auto px-6 py-24 md:py-32 text-center">
      <p class="text-[10px] uppercase tracking-[0.35em] text-coffee mb-5">{menu.season.sub}</p>
      <h2 class="italic-display text-4xl md:text-6xl text-ink lowercase leading-[1.1]">
        {menu.season.tagline}
      </h2>
      <p class="mt-10 text-coffee/80 leading-[1.8] max-w-2xl mx-auto">
        {menu.season.body}
      </p>
    </div>
  </section>

  <section class="bg-cream">
    <div class="max-w-5xl mx-auto px-6 py-20 md:py-28 space-y-12 md:space-y-16">
      {boards.map((b) => (
        <figure class="group">
          <img
            src={b.src}
            alt={b.alt}
            class="w-full h-auto rounded-sm shadow-xl shadow-ink/10 border border-ink/5"
            loading="lazy"
          />
          <figcaption class="sr-only">{b.label}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="bg-ink text-cream-warm">
    <div class="max-w-3xl mx-auto px-6 py-24 md:py-32 text-center">
      <h2 class="italic-display text-4xl md:text-6xl text-cream-warm lowercase leading-[1.1]">
        curious about the numbers?
      </h2>
      <p class="mt-8 text-cream-warm/75 leading-[1.8] max-w-xl mx-auto">
        Use our macro calculator to see the calories, protein, carbs and fats in every bowl you build.
      </p>
      <a
        href="/calculator"
        class="inline-flex mt-10 items-center gap-2 rounded-full border border-cream-warm/50 hover:bg-cream-warm hover:text-ink text-cream-warm text-[11px] uppercase tracking-[0.3em] px-7 py-3 transition-colors"
      >
        Open macro calculator
      </a>
    </div>
  </section>
</Layout>
